data/launcher_config.json
data/runtime.json
data/bootstrap/

# Headless Browser Debugging Profile
chrome-debug-profile/

# Node.js dependencies
node_modules/
npm-debug.log*

# Operating System Files
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/
